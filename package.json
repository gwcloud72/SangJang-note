{
  "name": "sangjang-note",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js --host 0.0.0.0",
    "build": "node node_modules/vite/bin/vite.js build",
    "preview": "node node_modules/vite/bin/vite.js preview --host 0.0.0.0",
    "update:data": "node scripts/update-ipos.mjs",
    "validate:data": "node scripts/validate-data.mjs",
    "generate:report": "node scripts/generate-ai-report.mjs",
    "quality:check": "node scripts/quality-check.mjs",
    "data:check": "node scripts/data-contract-check.mjs",
    "qa:check": "npm run quality:check && npm run ui-copy:check && npm run selector:check && npm run data:check && npm run interaction:check && npm run render:check",
    "interaction:check": "node scripts/interaction-check.mjs",
    "render:check": "node scripts/render-check.mjs",
    "actions:check": "node scripts/github-actions-contract-check.mjs",
    "verify:deps": "node -e \"const fs=require('fs'); for (const p of ['node_modules/vite/bin/vite.js','node_modules/typescript/bin/tsc','node_modules/@vitejs/plugin-react']) { if (!fs.existsSync(p)) { console.error('missing '+p); process.exit(1); } } console.log('vite dependency ready')\"",
    "deploy:check": "npm run verify:deps && npm run actions:check && npm run gemini:check && npm run competition:check && npm run briefings:check && npm run data:check && npm run sanitize:derived && npm run alerts:check && npm run validate:data && npm run quality:check && npm run runtime-ui:check && npm run interaction:check && npm run render:check && npm run typecheck && npm run build",
    "ci:check": "npm run deploy:check",
    "runtime-ui:check": "node scripts/runtime-ui-contract-check.mjs",
    "update:news": "node scripts/update-news.mjs",
    "generate:all": "npm run update:data && npm run update:news && npm run generate:report && npm run generate:briefings",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit",
    "gemini:check": "node scripts/gemini-flash-contract-check.mjs",
    "ui-copy:check": "node scripts/ui-copy-policy-check.mjs",
    "selector:check": "node scripts/selector-audit.mjs",
    "collect:competition-news": "node scripts/collect-ipo-competition-news.mjs",
    "competition:add-snapshot": "node scripts/add-competition-snapshot.mjs",
    "competition:check": "node scripts/competition-parser-check.mjs",
    "generate:briefings": "node scripts/generate-ipo-briefings.mjs",
    "briefings:check": "node scripts/briefings-contract-check.mjs",
    "actions:sample": "node scripts/sample-github-actions-data.mjs",
    "alerts:check": "node scripts/alert-contract-check.mjs",
    "sanitize:derived": "node scripts/sanitize-derived-data.mjs"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "dayjs": "^1.11.13",
    "iconv-lite": "^0.7.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^5.4.21"
  },
  "engines": {
    "node": ">=20 <23",
    "npm": ">=10"
  }
}
